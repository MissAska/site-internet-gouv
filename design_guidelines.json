      "admin_dashboard_bg": "https://images.unsplash.com/photo-1628536250739-06f5353d6364?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAzMzJ8MHwxfHNlYXJjaHwxfHxuaWdodCUyMGNpdHklMjBza3lsaW5lJTIwYmx1ZSUyMGFlc3RoZXRpY3xlbnwwfHx8fDE3NzIzMTc2NDN8MA&ixlib=rb-4.1.0&q=85",
      "gov_icon": "https://images.unsplash.com/photo-1680992046626-418f7e910589?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAzOTB8MHwxfHNlYXJjaHwzfHxtb2Rlcm4lMjBzZXJ2ZXIlMjByb29tJTIwYmx1ZSUyMGxpZ2h0c3xlbnwwfHx8fDE3NzIzMTc2NDV8MA&ixlib=rb-4.1.0&q=85",
      "money_texture": "https://images.unsplash.com/photo-1710761522946-fb8b390547fd?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjY2NjV8MHwxfHNlYXJjaHwxfHxzdGFjayUyMG9mJTIwbW9uZXklMjBkb2xsYXIlMjBiaWxscyUyMGRhcmt8ZW58MHx8fHwxNzcyMzE3NjQ1fDA&ixlib=rb-4.1.0&q=85",
      "office_texture": "https://images.unsplash.com/photo-1758833502047-8f1c7dc5edd7?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NDk1Nzl8MHwxfHNlYXJjaHwyfHxsdXh1cnklMjBtb2Rlcm4lMjBvZmZpY2UlMjBpbnRlcmlvciUyMG5pZ2h0fGVufDB8fHx8MTc3MjMxNzY0Nnww&ixlib=rb-4.1.0&q=85"
    },
    "icons": {
      "library": "lucide-react",
      "recommended": ["Building2", "Users", "Briefcase", "DollarSign", "Landmark", "FileText", "Activity", "LogOut", "Settings", "TrendingUp", "TrendingDown"]
    }
  },
  "motion": {
    "transitions": "transition-all duration-200 ease-in-out",
    "hover": "hover:translate-y-[-2px] hover:shadow-glow",
    "page_load": "animate-in fade-in zoom-in-95 duration-300",
    "list_item": "animate-in slide-in-from-left-4 duration-300 stagger-100"
  },
  "instructions_to_main_agent": [
    "INSTALL FONTS: Add '@fontsource/chakra-petch', '@fontsource/ibm-plex-sans', and '@fontsource/jetbrains-mono' to package.json immediately.",
    "THEME SETUP: Ensure tailwind.config.js has the specific colors defined in 'design_system.colors'. Extend the theme, do not overwrite default Tailwind colors unless necessary.",
    "LAYOUT: Use a Sidebar Layout for all logged-in pages. The sidebar should be collapsible on mobile.",
    "DATA DISPLAY: All financial values must be formatted as currency (e.g., '$ 1,200,000') and right-aligned in tables.",
    "CHARTING: Use Recharts for the 'Comptabilité' page. Style the lines/bars with the primary and success colors defined.",
    "FORMS: Use Shadcn Form components. Ensure validation messages are visible in Red-500.",
    "TAX SYSTEM: The 'Avis d'impôts' generation should be visually distinct - maybe look like a paper document or a specialized alert card.",
    "ACCESSIBILITY: Ensure text contrast ratios are met. The blue text on slate background is risky, verify contrast."
  ],
  "universal_guidelines": [
    "Avoid generic 'center-everything' layouts. Use grids.",
    "No gradients for backgrounds unless it's a very subtle noise texture.",
    "Use 'data-testid' on all interactive elements.",
    "Dark mode ONLY. Do not implement light mode toggle.",
    "French language interface is mandatory."
  ]
}